{
  "name": "android-test-automation",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "wdio run ./wdio.conf.js",
    "test:basic": "wdio run ./wdio.conf.js --spec ./tests/basic/*.test.js",
    "test:connectivity": "wdio run ./wdio.conf.js --spec ./tests/connectivity/*.test.js",
    "test:camera": "wdio run ./wdio.conf.js --spec ./tests/camera/*.test.js",
    "test:sensors": "wdio run ./wdio.conf.js --spec ./tests/sensors/*.test.js",
    "test:performance": "wdio run ./wdio.conf.js --spec ./tests/performance/*.test.js",
    "appium": "appium --allow-insecure *:adb_shell --use-plugins=inspector --allow-cors"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@wdio/cli": "^9.24.0",
    "@wdio/local-runner": "^9.24.0",
    "@wdio/mocha-framework": "^9.24.0",
    "@wdio/spec-reporter": "^9.24.0",
    "appium": "^3.2.0",
    "appium-inspector-plugin": "^2026.2.1",
    "appium-uiautomator2-driver": "^7.0.0"
  }
}
